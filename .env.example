# === Required ===
FUTU_LOGIN_ACCOUNT=
# Use MD5 password (recommended) - 32-bit hex, e.g.: echo -n "yourpassword" | md5sum
FUTU_LOGIN_PWD_MD5=
# Or use plaintext password (not recommended)
# FUTU_LOGIN_PWD=

# === Ports ===
FUTU_API_PORT=11111
# FUTU_WEBSOCKET_PORT=33333

# === Optional ===
FUTU_LANG=en
FUTU_LOG_LEVEL=info
FUTU_PUSH_PROTO_TYPE=0
FUTU_TIMEZONE=UTC+8
FUTU_PRICE_REMINDER_PUSH=1
FUTU_AUTO_HOLD_QUOTE_RIGHT=1

# === Security ===
# Path inside container where RSA key is mounted
# FUTU_RSA_KEY_PATH=/secrets/rsa_private.pem
# FUTU_WEBSOCKET_KEY_MD5=

# === FUTU US ===
# FUTU_PDT_PROTECTION=1
